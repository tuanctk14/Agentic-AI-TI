# ╔══════════════════════════════════════════════════════════════╗
# ║        ArgusWatch AI v16.4.7 - Environment Configuration   ║
# ║        Solvent CyberSecurity LLC                           ║
# ╚══════════════════════════════════════════════════════════════╝
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git - it contains your real API keys
# ──────────────────────────────────────────────────────────────


# ──────────────────────────────────────────────────────────────
# 🦙 AI MODEL - Local Qwen via Ollama (free, private, fast)
# ──────────────────────────────────────────────────────────────
#
# OPTION A: Native Ollama (RECOMMENDED - gets GPU acceleration)
#   Install: winget install Ollama.Ollama (Windows) or curl -fsSL https://ollama.com/install.sh | sh (Linux)
#   Pull: ollama pull qwen3:8b
#   Set: OLLAMA_URL=http://host.docker.internal:11434
#
# OPTION B: Docker Ollama (CPU only, slower)
#   Leave OLLAMA_URL as default (http://ollama:11434)
#   Model downloads automatically on first boot (~6.6GB)

OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:8b
# Alternatives: qwen3:4b (lighter), qwen3:8b (balanced), qwen3.5:9b (best, when supported)


# ──────────────────────────────────────────────────────────────
# 🤖 CLOUD AI PROVIDERS (optional - local Ollama runs for free)
# ──────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=
# Claude - https://console.anthropic.com/settings/keys

OPENAI_API_KEY=
# GPT-4o - https://platform.openai.com/api-keys

GOOGLE_AI_API_KEY=
# Gemini - https://aistudio.google.com/app/apikey


# ──────────────────────────────────────────────────────────────
# 🆓 FREE KEYS - get all in under 10 minutes ($0)
# ──────────────────────────────────────────────────────────────

GITHUB_TOKEN=
# Classic token, zero scopes - https://github.com/settings/tokens
# Unlocks: GitHub Gist scraper (5000 req/hr) + GitHub Secrets search

OTX_API_KEY=
# AlienVault OTX - https://otx.alienvault.com/ (Sign up -> Settings -> API Key)
# Unlocks: 200K+ community threat intel pulses

URLSCAN_API_KEY=
# URLScan.io - https://urlscan.io/user/signup/ (API tab)
# Unlocks: 1000 phishing/malware URL scans per day

CENSYS_API_ID=
CENSYS_API_SECRET=
# Censys - https://search.censys.io/account/api (Free tier)
# Unlocks: exposed certificates + services per customer domain

ABUSEIPDB_API_KEY=
# AbuseIPDB - https://www.abuseipdb.com/account/api (Free tier)
# Unlocks: IP reputation checks (1000/day)


# ──────────────────────────────────────────────────────────────
# 💰 PAID KEYS - high value, low cost
# ──────────────────────────────────────────────────────────────

