# ╔══════════════════════════════════════════════════════════════╗
# ║  DATABASE (REQUIRED - no defaults, must be set)             ║
# ╚══════════════════════════════════════════════════════════════╝

POSTGRES_USER=arguswatch
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=arguswatch

# ╔══════════════════════════════════════════════════════════════╗
# ║  AUTH (REQUIRED - change in production)                     ║
# ╚══════════════════════════════════════════════════════════════╝

AUTH_DISABLED=true
JWT_SECRET_KEY=CHANGE_ME_RANDOM_64_CHAR_STRING
JWT_EXPIRE_HOURS=24
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
