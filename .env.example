GRAYHATWARFARE_API_KEY=
# GrayHatWarfare - https://grayhatwarfare.com/api (Free tier)
# Unlocks: find open S3/Azure/GCS buckets per customer domain

LEAKIX_API_KEY=
# LeakIX - https://leakix.net/auth/login (Free tier)
# Unlocks: exposed services + leaked data per customer

PULSEDIVE_API_KEY=
# Pulsedive - https://pulsedive.com/account (Free tier)
# Unlocks: community threat intel enrichment

INTELX_API_KEY=
# Intelligence X - https://intelx.io/account?tab=developer (paid)
