# ──────────────────────────────────────────────────────────────
# 📱 TELEGRAM - free, monitors public threat intel channels
# ──────────────────────────────────────────────────────────────

TELEGRAM_BOT_TOKEN=
# Optional - only needed for private channels
# Public channels work without any token

TELEGRAM_CHANNELS=
# Comma-separated channel names (no @)
# Default: darkwebinformer,RansomwareLeaks,infosec_news
# Example: TELEGRAM_CHANNELS=darkwebinformer,your_channel


